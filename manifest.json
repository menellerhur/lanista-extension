{
  "manifest_version": 3,
  "name": "Lanista Extension",
  "version": "1.2",
  "description": "Tillägg för spelet Lanista: https://beta.lanista.se/",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["data/*.json"],
      "matches": ["https://beta.lanista.se/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://beta.lanista.se/*"],
      "js": [
        "js/main-world/network-interceptor.js",
        "js/main-world/app-connector.js",
        "js/main-world/socket-listener.js",
        "js/main-world/state-synchronizer.js",
        "js/main-world/store-bridge.js",
        "js/main-world/router-observer.js",
        "js/main-world/bus-listener.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://beta.lanista.se/*"],
      "js": [
        "js/isolated-world/common/constants.js",
        "js/isolated-world/common/utils.js",
        "js/isolated-world/common/items-data.js",
        "js/isolated-world/common/icons.js",
        "js/isolated-world/common/settings.js",
        "js/isolated-world/common/api-handler.js",
        "js/isolated-world/features/sidebar.js",
        "js/isolated-world/pages/notifications/page.js",
        "js/isolated-world/common/page-navigation.js",
        "js/isolated-world/pages/extension/templates.js",
        "js/isolated-world/pages/extension/page-builder.js",
        "js/isolated-world/pages/extension/page-handlers.js",
        "js/isolated-world/pages/extension/page.js",
        "js/isolated-world/features/auctions.js",
        "js/isolated-world/features/teambattles.js",
        "js/isolated-world/features/team-beasts-quota.js",
        "js/isolated-world/features/tournament/main.js",
        "js/isolated-world/features/tournament/preview.js",
        "js/isolated-world/features/tournament/reports-menu.js",
        "js/isolated-world/features/tournament/parse.js",
        "js/isolated-world/features/tournament/render.js",
        "js/isolated-world/features/tournament/info-layout.js",
        "js/isolated-world/features/merchants.js",
        "js/isolated-world/main.js",
        "js/isolated-world/features/nav/badges.js",
        "js/isolated-world/features/right-panel-collapse.js",
        "js/isolated-world/features/nav/enhancements.js",
        "js/isolated-world/features/nav/merge.js",
        "js/isolated-world/features/nav/hide-empty.js",
        "js/isolated-world/features/nav/simplify-community.js",
        "js/isolated-world/features/nav/cooldowns.js",
        "js/isolated-world/features/nav/avatar-sync.js",
        "js/isolated-world/features/nav/tournament-times.js",
        "js/isolated-world/features/nav/ranked-battle-time.js",
        "js/isolated-world/features/nav/ranked-battle.js",
        "js/isolated-world/features/battle-report/manager.js",
        "js/isolated-world/features/battle-report/actions.js",
        "js/isolated-world/features/battle-report/stats.js",
        "js/isolated-world/features/battle-report/colors.js",
        "js/isolated-world/features/battle-report/init.js",
        "js/isolated-world/features/avatar-info.js",
        "js/isolated-world/features/avatar-statistics.js",
        "js/isolated-world/common/item-tooltip.js",
        "js/isolated-world/pages/database/config.js",
        "js/isolated-world/pages/database/state.js",
        "js/isolated-world/pages/database/filters.js",
        "js/isolated-world/pages/database/tables.js",
        "js/isolated-world/pages/database/columns.js",
        "js/isolated-world/pages/database/ui-tooltip.js",
        "js/isolated-world/pages/database/ui-selection.js",
        "js/isolated-world/pages/database/ui-filters-summary.js",
        "js/isolated-world/pages/database/ui-table-refresh.js",
        "js/isolated-world/pages/database/ui-subcats.js",
        "js/isolated-world/pages/database/ui-col-picker.js",
        "js/isolated-world/pages/database/ui-col-filter.js",
        "js/isolated-world/pages/database/ui.js",
        "js/isolated-world/pages/database/page.js",
        "js/isolated-world/pages/plan-gladiator/state.js",
        "js/isolated-world/pages/plan-gladiator/ages.js",
        "js/isolated-world/pages/plan-gladiator/storage.js",
        "js/isolated-world/pages/plan-gladiator/data.js",
        "js/isolated-world/pages/plan-gladiator/stats.js",
        "js/isolated-world/pages/plan-gladiator/dropdown.js",
        "js/isolated-world/pages/plan-gladiator/step-profile.js",
        "js/isolated-world/pages/plan-gladiator/step-utrustning.js",
        "js/isolated-world/pages/plan-gladiator/age-tooltip.js",
        "js/isolated-world/pages/plan-gladiator/step-egenskaper-table.js",
        "js/isolated-world/pages/plan-gladiator/step-egenskaper-grade.js",
        "js/isolated-world/pages/plan-gladiator/step-egenskaper.js",
        "js/isolated-world/pages/plan-gladiator/breadcrumb.js",
        "js/isolated-world/pages/plan-gladiator/sync-mapper.js",
        "js/isolated-world/pages/plan-gladiator/sync-apply.js",
        "js/isolated-world/pages/plan-gladiator/sync-modal.js",
        "js/isolated-world/pages/plan-gladiator/unsaved-changes-modal.js",
        "js/isolated-world/pages/plan-gladiator/confirm-modal.js",
        "js/isolated-world/pages/plan-gladiator/page.js"
      ],
      "css": [
        "styles/overrides.css",
        "styles/merchants.css",
        "styles/settings-panel.css",
        "styles/database.css",
        "styles/plan-gladiator.css",
        "styles/tournament-bracket.css",
        "styles/misc.css",
        "styles/battle-report.css"
      ],
      "run_at": "document_end"
    }
  ]
}
